{
  "name": "sakura-market---infinite-2d-marketplace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:all": "node server.js",
    "dev:mobile": "set NODE_ENV=production&& npm run build&& node server.js",
    "build": "next build",
    "start": "node server.js",
    "start:all": "node server.js",
    "pm2:start": "pm2 start server.js --name sakura-app",
    "pm2:restart": "pm2 restart sakura-app",
    "lint": "next lint",
    "db:init": "node scripts/db-init.js",
    "db:check-schema": "node scripts/check-schema-status.js",
    "db:clear": "node scripts/db-clear.js",
    "db:clear-users": "node scripts/db-clear-users.js",
    "uploads:check": "node scripts/check-uploads-usage.js",
    "uploads:clean": "node scripts/check-uploads-usage.js --delete",
    "db:backfill-ad-credits": "node scripts/backfill-ad-credits-from-plan.js",
    "db:seed-admin": "node scripts/seed-first-admin.js",
    "cron:release-offline-locks": "node scripts/release-offline-shop-locks.js",
    "socket": "node socket-server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "heic-convert": "^2.1.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "pixi.js": "^8.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "viem": "^2.47.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.8.2"
