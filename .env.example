# =============================================================================
# Sakura Market — ตัวอย่างตัวแปรสภาพแวดล้อม (.env)
# =============================================================================
# คัดลอกเป็น .env แล้วใส่ค่าจริง (ห้าม commit ไฟล์ .env)
# โปรเจกต์ใช้ Custom Server (Next + Socket.io process เดียว) — โดเมนเดียว
# =============================================================================

# -----------------------------------------------------------------------------
# แอป (App)
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
# โหมดเดโม: เปิดแล้วผูกกระเป๋า/ตั้งราคา/ซื้อขายได้ แต่ไม่หักเงิน (user_balances) และไม่หักเครดิตโฆษณา (user_ad_credits)
# DEMO_MODE=true   → backend ไม่หักยอดจริง (คำสั่งซื้อ, โข่ง/ป้าย, จองที่, แพ็กเกจ, โฆษณา)
# NEXT_PUBLIC_DEMO_MODE=true → ฝั่งแอปแสดงป้าย "โหมดเดโม" ได้ (ใส่คู่กับ DEMO_MODE เมื่อต้องการ)
# DEMO_MODE=
# NEXT_PUBLIC_DEMO_MODE=
# URL หลักของแอป — Local: ว่าง | Tunnel: https://xxx.trycloudflare.com | Production: https://yourdomain.com
# ถ้ากำหนดค่า next.config จะใช้ host เป็น allowedDevOrigins (ให้มือถือเข้าแอปผ่าน tunnel ได้)
BASE_URL=

# -----------------------------------------------------------------------------
# WebSockets (Real-time) — process เดียว ใช้พอร์ตเดียวกับแอป
# -----------------------------------------------------------------------------
# ใช้ใน API ฝั่งเซิร์ฟเวอร์ (เช่น emit เมื่อมีผู้ใช้สมัคร) — ชี้ไปที่ process เดียวกัน
SOCKET_URL=http://localhost:3000
# ใช้ใน Frontend — Local: http://localhost:3000 | Production: https://yourdomain.com
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# ฐานข้อมูล PostgreSQL
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sakuramarket
DB_USER=postgres
DB_PASSWORD=your_password

# -----------------------------------------------------------------------------
# Web3 (ผูกกระเป๋า + กระเป๋ากลาง + โทเค็นมีมคอย)
# -----------------------------------------------------------------------------
# แยกเป็น 2 กลุ่ม: [Dev ตั้งเองได้] กับ [ต้องขอจากเจ้าของกระเป๋า/ผู้สร้างมีมคอย/บริการภายนอก]
# ย้อนมาหาได้จาก comment ด้านล่าง
# -----------------------------------------------------------------------------

# ---------- [Dev ตั้งเองได้] — เปิด/ปิด, เลือก chain, RPC, สร้าง API key, ตั้ง decimals ----------
# เปิด/ปิดฟีเจอร์ Web3 ฝั่ง UI
NEXT_PUBLIC_WEB3_ENABLED=true
# เครือข่ายหลักที่ให้ลูกค้าเชื่อม (137 = Polygon Mainnet, 80002 = Polygon Amoy)
NEXT_PUBLIC_WEB3_CHAIN_ID=137
# RPC สำหรับอ่านข้อมูล chain ฝั่ง client/server (ใช้ public หรือของทีม)
NEXT_PUBLIC_WEB3_RPC_URL=https://polygon-rpc.com
WEB3_RPC_URL=https://polygon-rpc.com
# คีย์ป้องกัน API ภายใน (auto payout/settlement) — Dev สร้าง/กำหนดเอง
WEB3_INTERNAL_API_KEY=
# decimals ของโทเค็น (ส่วนใหญ่ ERC-20 ใช้ 18) — ตั้งตามสเปกโทเค็น
APP_TOKEN_DECIMALS=18

# ---------- [ต้องขอจากภายนอก] — เจ้าของกระเป๋ากลาง / ผู้สร้างมีมคอย / WalletConnect / Price Feed ----------
# ที่อยู่กระเป๋ากลางของแพลตฟอร์ม — ขอจากเจ้าของกระเป๋ากลาง (public ได้)
PLATFORM_WALLET_ADDRESS=
# private key กระเป๋ากลาง — ขอจากเจ้าของกระเป๋ากลาง เท่านั้น (ห้ามเปิดเผย/ห้าม commit)
PLATFORM_WALLET_PRIVATE_KEY=
# สัญญาโทเค็นของแอป (ERC-20) — ขอจากผู้สร้าง/deploy มีมคอย หลัง deploy แล้ว
APP_TOKEN_CONTRACT_ADDRESS=
# รองรับการอ่านฝั่ง client (ใช้ contract address เดียวกับบรรทัดบน)
NEXT_PUBLIC_APP_TOKEN_CONTRACT_ADDRESS=
# WalletConnect Project ID — สมัครที่ cloud.walletconnect.com แล้วใส่
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# API แปลงราคาเหรียญ (ใช้ตอนทำระบบเติมเหรียญจากหลาย token) — ขอจากผู้ให้บริการ price feed
PRICE_FEED_API_KEY=

# -----------------------------------------------------------------------------
# JWT (การเข้าใช้งาน)
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
# ชั่วโมงก่อนหมดอายุที่ให้ re-issue cookie (sliding session) — ไม่กำหนดใช้ 24
JWT_REFRESH_THRESHOLD_HOURS=24

# -----------------------------------------------------------------------------
# แอดมิน (CMS) — ล็อกอินใช้ตาราง admins ในฐานข้อมูลเท่านั้น (เพิ่มแอดมินจากเมนู จัดการแอดมิน หรือรัน node scripts/seed-first-admin.js)
# -----------------------------------------------------------------------------
# LINE สำหรับปุ่ม "ติดต่อเช่าล็อค" (ลิงก์เต็ม เช่น https://line.me/ti/p/~xxx หรือ @id)
NEXT_PUBLIC_ADMIN_LINE=

# -----------------------------------------------------------------------------
# SMTP (Brevo) — ส่ง OTP
# -----------------------------------------------------------------------------
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@domain.com
SMTP_PASS=your-brevo-smtp-key
EMAIL_FROM=your-smtp-user@domain.com
EMAIL_FROM_NAME=Sakura Market

# -----------------------------------------------------------------------------
# OTP
# -----------------------------------------------------------------------------
OTP_EXPIRY_MINUTES=5
OTP_COOLDOWN_MINUTES=5
OTP_CODE_LENGTH=6
MAX_OTP_ATTEMPTS=5

# -----------------------------------------------------------------------------
# Cron — ปลดล็อคร้านที่เจ้าของไม่ออนไลน์เกิน N วัน
# -----------------------------------------------------------------------------
# จำนวนวันที่ถือว่า "ออฟไลน์ติดต่อกัน" แล้วปลดล็อคจองแผนที่ (ค่าเริ่มต้น 7)
OFFLINE_DAYS_RELEASE=7
# ถ้ากำหนด CRON_SECRET การเรียก GET/POST /api/cron/* (release-offline-locks, cleanup-old-notifications ฯลฯ) ต้องส่ง header X-Cron-Secret: <ค่าเดียวกัน>
# CRON_SECRET=
# ปิดการรันปลดล็อคอัตโนมัติในตัว (เมื่อใช้ cron ภายนอก): CRON_RELEASE_OFFLINE_ENABLED=false

# ลบแจ้งเตือนเก่ากว่ากำหนด — จำนวนวัน (ค่าเริ่มต้น 10) ใช้กับ /api/cron/cleanup-old-notifications และ scripts/cleanup-old-notifications.js
NOTIFICATION_RETENTION_DAYS=10
# ลบแจ้งเตือนรันอัตโนมัติทุก 10 วันจาก server.js — ค่าเริ่มต้นคือเปิดอยู่แล้ว ไม่ต้องตั้งก็ได้ / ใส่ false ถ้าต้องการปิด
CRON_CLEANUP_NOTIFICATIONS_ENABLED=true

# -----------------------------------------------------------------------------
# อัปโหลดไฟล์ (รูปภาพ ฯลฯ)
# -----------------------------------------------------------------------------
# เปิดใช้ Google Drive เป็นที่เก็บ: true = อัปโหลดไป Drive, false หรือไม่กำหนด = เก็บใน public/uploads (local)
UPLOAD_USE_GOOGLE_DRIVE=false

# เมื่อ UPLOAD_USE_GOOGLE_DRIVE=true — อ่าน credentials จากไฟล์ที่ได้จาก Google (ห้าม commit ไฟล์นี้)
# รับรองรูปแบบ: (1) Service Account JSON ที่ดาวน์โหลดจาก Google Cloud หรือ (2) JSON ที่มี client_id, client_secret, refresh_token
GOOGLE_DRIVE_CREDENTIALS_FILE=./secrets/google-drive-credentials.json

# ไอดีโฟลเดอร์ใน Drive — ต้องแชร์โฟลเดอร์ให้ Service Account (client_email ใน credentials) ด้วยสิทธิ์ "ผู้แก้ไข"
# ถ้าใช้ root ของ Drive ของ Service Account ให้ใส่ GOOGLE_DRIVE_FOLDER_ID=root (หรือปล่อยว่าง)
# GOOGLE_DRIVE_FOLDER_ID=     ไอดีโฟลเดอร์หลัก (ถ้าว่างใช้ root)
# GOOGLE_DRIVE_UPLOADS_FOLDER_ID=   ไอดีโฟลเดอร์ย่อยที่ใช้เก็บอัปโหลด (ถ้าว่างใช้ค่า GOOGLE_DRIVE_FOLDER_ID)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_UPLOADS_FOLDER_ID=
